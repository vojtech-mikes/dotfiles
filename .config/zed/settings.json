// Zed settings
{
  "features": {
    "inline_completion_provider": "none"
  },
  "base_keymap": "JetBrains",
  "buffer_font_features": {
    "calt": false
  },
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "system",
    "light": "Andromeda",
    "dark": "Gruber Darker"
  },
  "vim_mode": true,
  "relative_line_numbers": true,
  "autosave": "on_window_change",
  "languages": {
    "Python": {
      "format_on_save": {
        "external": {
          "command": "/opt/homebrew/bin/black",
          "arguments": ["-", "--line-length", "80"]
        }
      }
    }
  },
  "chat_panel": { "button": false },
  "notification_panel": { "button": false },
  "assistant": { "button": false, "version": "2" },
  "collaboration_panel": {
    "button": false
  },
  "cursor_blink": false
}
